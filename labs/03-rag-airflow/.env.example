# ==========================================
# Airflow 3 + RAG (Lab 03 & 04)
# ==========================================

# 1. รหัสลับสำหรับ Gemini API (จำเป็นต้องใส่)
# เปลี่ยนคำว่า YOUR_API_KEY_HERE เป็นคีย์จริงๆ ที่ได้จาก Google AI Studio
GEMINI_API_KEY=YOUR_API_KEY_HERE

# 2. รหัสสำหรับตั้งค่า Permissions ของ Airflow 
# (สำหรับผู้ใช้ Mac/Linux ให้เปลี่ยนเป็น UID ของตัวเองเพื่อป้องกันสิทธิ์ไฟล์ล็อก)
# (สำหรับ Windows ปล่อยไว้ที่ 50000 หรือเปลี่ยนเป็น 1000 ก็ได้ครับ)
AIRFLOW_UID=50000
